MAIL_USERNAME=your-smtp-account@gmail.com
MAIL_PASSWORD=your-new-gmail-app-password
MAIL_FROM=your-smtp-account@gmail.com

# Flutter / web / mobile placeholders. Override with --dart-define or CI secrets.
CHESSVERSE_ENV=local
API_BASE_URL=https://api.chessverse.example
WEB_BASE_URL=https://play.chessverse.example
PRIVACY_POLICY_URL=https://chessverse.example/privacy
TERMS_URL=https://chessverse.example/terms
DATA_DELETION_URL=https://chessverse.example/data-deletion

# Social login placeholders. Keep real values in CI/VPS secrets, not in git.
GOOGLE_WEB_CLIENT_ID=replace-google-web-client-id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=replace-google-android-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=replace-google-ios-client-id.apps.googleusercontent.com
APPLE_SERVICE_ID=com.epitomehub.chessverse.signin
APPLE_REDIRECT_URI=https://api.chessverse.example/api/auth/apple/callback
FACEBOOK_APP_ID=replace-facebook-app-id
FACEBOOK_CLIENT_TOKEN=replace-facebook-client-token

# Required by the production backend.
DB_URL=jdbc:postgresql://your-postgres-host:5432/chessverse
DB_USERNAME=chessverse
DB_PASSWORD=replace-with-a-managed-secret
ALLOWED_ORIGIN_PATTERNS=https://app.your-chessverse-domain.com
AUTH_RESEND_COOLDOWN_SECONDS=60
AUTH_LOGIN_LOCKOUT_MINUTES=15
AUTH_RATE_LIMIT_ENABLED=true
AUTH_DELIVERY=mail

# Official Stockfish UCI executable used by the backend AI service.
STOCKFISH_PATH=
STOCKFISH_TIMEOUT_SECONDS=5
