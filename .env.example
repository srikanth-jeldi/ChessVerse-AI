MAIL_USERNAME=your-smtp-account@gmail.com
MAIL_PASSWORD=your-new-gmail-app-password
MAIL_FROM=your-smtp-account@gmail.com

# Required by the production backend.
DB_URL=jdbc:postgresql://your-postgres-host:5432/chessverse
DB_USERNAME=chessverse
DB_PASSWORD=replace-with-a-managed-secret
ALLOWED_ORIGIN_PATTERNS=https://app.your-chessverse-domain.com
AUTH_RESEND_COOLDOWN_SECONDS=60
AUTH_LOGIN_LOCKOUT_MINUTES=15
AUTH_RATE_LIMIT_ENABLED=true
AUTH_DELIVERY=mail

# Official Stockfish UCI executable used by the backend AI service.
STOCKFISH_PATH=
STOCKFISH_TIMEOUT_SECONDS=5
