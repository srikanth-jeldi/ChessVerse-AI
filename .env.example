MAIL_USERNAME=your-smtp-account@gmail.com
MAIL_PASSWORD=your-new-gmail-app-password
MAIL_FROM=your-smtp-account@gmail.com

# OAuth public identifiers. Keep Apple private keys in a secret manager.
GOOGLE_WEB_CLIENT_ID=
GOOGLE_SERVER_CLIENT_ID=
APPLE_SERVICE_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=
APPLE_REDIRECT_URI=

# Phone OTP gateway. Point this to an HTTPS service that accepts
# {"to": "+919876543210", "from": "ChessVerse", "message": "..."}.
SMS_GATEWAY_URL=
SMS_GATEWAY_TOKEN=
SMS_SENDER=ChessVerse
