MAIL_USERNAME=your-smtp-account@gmail.com
MAIL_PASSWORD=your-new-gmail-app-password
MAIL_FROM=your-smtp-account@gmail.com

# OAuth public identifiers.
GOOGLE_WEB_CLIENT_ID=
GOOGLE_SERVER_CLIENT_ID=
# Comma-separated Web, Android, iOS and server client IDs accepted by backend.
GOOGLE_CLIENT_IDS=

# Phone OTP gateway. Point this to an HTTPS service that accepts
# {"to": "+919876543210", "from": "ChessVerse", "message": "..."}.
SMS_GATEWAY_URL=
SMS_GATEWAY_TOKEN=
SMS_SENDER=ChessVerse
SMS_MODE=sns

# Native Amazon SNS mode. AWS SDK uses the default AWS credential chain.
# Use ap-south-1 for India local-route production SMS.
AWS_REGION=ap-south-1
SMS_SENDER_ID=
SMS_MAX_PRICE=
SMS_INDIA_ENTITY_ID=
SMS_INDIA_TEMPLATE_ID=

# Official Stockfish UCI executable used by the backend AI service.
STOCKFISH_PATH=
STOCKFISH_TIMEOUT_SECONDS=5
