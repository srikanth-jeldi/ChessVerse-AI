# Copy this file to vps.env on the server. Never commit vps.env.
APP_DOMAIN=play.example.com
API_DOMAIN=api.example.com
ACME_EMAIL=admin@example.com
PRIVACY_POLICY_URL=https://play.example.com/privacy
TERMS_URL=https://play.example.com/terms
DATA_DELETION_URL=https://play.example.com/data-deletion

POSTGRES_DB=chessverse
POSTGRES_USER=chessverse
POSTGRES_PASSWORD=replace-with-a-long-random-password

MAIL_USERNAME=your-smtp-account@gmail.com
MAIL_PASSWORD=your-16-character-gmail-app-password
MAIL_FROM=your-smtp-account@gmail.com

# OAuth / store login placeholders. Replace on VPS/CI when Google, Apple, and Meta apps are approved.
GOOGLE_WEB_CLIENT_ID=replace-google-web-client-id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=replace-google-android-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=replace-google-ios-client-id.apps.googleusercontent.com
APPLE_SERVICE_ID=com.epitomehub.chessverse.signin
APPLE_REDIRECT_URI=https://api.example.com/api/auth/apple/callback
FACEBOOK_APP_ID=replace-facebook-app-id
FACEBOOK_CLIENT_TOKEN=replace-facebook-client-token

# Optional rclone destination, for example: b2:chessverse-backups
BACKUP_REMOTE=
BACKUP_RETENTION_DAYS=14
